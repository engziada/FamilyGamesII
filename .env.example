# Environment Variables for FamilyGamesII

# Flask Secret Key - Generate a strong random key for production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Groq AI API Key for trivia question translation
# Get your free API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Convex Deployment URL (from .env.local after `npx convex dev`)
# Example: https://your-project-123.convex.cloud
CONVEX_URL=your_convex_deployment_url_here
